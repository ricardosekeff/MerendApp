# ============================================================
# MerendApp — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ============================================================

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Banco de Dados (PostgreSQL) ────────────────────────────
POSTGRES_DB=merendapp
POSTGRES_USER=merendapp_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://merendapp_user:change-me-strong-password@postgres:5432/merendapp

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-very-long-and-random
JWT_ACCESS_TOKEN_EXPIRES=900     # 15 minutos (em segundos)
JWT_REFRESH_TOKEN_EXPIRES=604800 # 7 dias (em segundos)

# ── Gateway de Pagamento ───────────────────────────────────
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=
PAYMENT_GATEWAY_BASE_URL=https://api.pagamento.com.br

# ── App ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost
DEFAULT_TOKEN_EXPIRY_MINUTES=30
